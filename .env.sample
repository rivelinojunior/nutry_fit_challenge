# Copy this file to .env and fill in the values needed for your environment.

# Database
DATABASE_USERNAME=nutry_fit_admin
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5437

# Optional: use a full database URL instead of the individual values above
# DATABASE_URL=postgres://nutry_fit_admin:@localhost:5437/nutry_fit_challenge_development

# Rails / Puma
PORT=3000
RAILS_MAX_THREADS=5
JOB_CONCURRENCY=1

# Optional process tuning
# SOLID_QUEUE_IN_PUMA=true
# PIDFILE=tmp/pids/server.pid
# WEB_CONCURRENCY=2

# Optional production-oriented settings
# RAILS_LOG_LEVEL=info
# SECRET_KEY_BASE=replace-me-for-production

# Kamal deployment
# RAILS_MASTER_KEY=replace-with-production-master-key
# KAMAL_REGISTRY_PASSWORD=replace-with-docker-hub-access-token
# POSTGRES_PASSWORD=replace-with-strong-postgres-password
