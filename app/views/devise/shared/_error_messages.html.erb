<% if resource.errors.any? %>
  <div class="alert alert-error mb-5 items-start text-sm">
    <div>
      <p class="font-semibold"><%= t("errors.messages.not_saved", count: resource.errors.count, resource: resource.class.model_name.human.downcase) %></p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
