<div class="mt-6 space-y-3 border-t border-base-300 pt-5 text-center text-sm text-base-content/70">
  <% if controller_name != "sessions" %>
    <p>
      Já tem uma conta?
      <%= link_to "Entrar", new_session_path(resource_name), class: "link link-hover font-semibold text-primary" %>
    </p>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <p>
      Novo por aqui?
      <%= link_to "Criar conta", new_registration_path(resource_name), class: "link link-hover font-semibold text-primary" %>
    </p>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p>
      <%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "link link-hover" %>
    </p>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <p>
      <%= link_to "Reenviar instruções de confirmação", new_confirmation_path(resource_name), class: "link link-hover" %>
    </p>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <p>
      <%= link_to "Reenviar instruções de desbloqueio", new_unlock_path(resource_name), class: "link link-hover" %>
    </p>
  <% end %>
</div>
