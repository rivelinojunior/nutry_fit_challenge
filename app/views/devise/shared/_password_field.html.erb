<% label_text = local_assigns.fetch(:label_text, nil) %>
<% autocomplete = local_assigns.fetch(:autocomplete, "current-password") %>
<% autofocus = local_assigns.fetch(:autofocus, false) %>
<% placeholder = local_assigns.fetch(:placeholder, nil) %>
<% hint = local_assigns.fetch(:hint, nil) %>
<% has_error = resource.errors[attribute].any? %>

<div>
  <% if label_text.present? %>
    <%= form.label attribute, label_text, class: "label pb-2 text-sm font-medium" %>
  <% end %>

  <div class="input input-bordered w-full <%= "input-error" if has_error %>" data-controller="password-visibility">
    <%= form.password_field attribute,
      autocomplete: autocomplete,
      autofocus: autofocus,
      placeholder: placeholder,
      class: "min-w-0 grow",
      data: { password_visibility_target: "input" } %>

    <button
      type="button"
      class="btn btn-ghost btn-sm -mr-2 size-8 rounded-md p-0 text-base-content/60 hover:text-primary"
      data-action="click->password-visibility#toggle"
      data-password-visibility-target="button"
      aria-label="Mostrar senha"
      aria-pressed="false"
      title="Mostrar senha">
      <svg data-password-visibility-target="showIcon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
        <circle cx="12" cy="12" r="3" />
      </svg>

      <svg data-password-visibility-target="hideIcon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.7 5.1A10.4 10.4 0 0 1 12 5c6.5 0 10 7 10 7a17.8 17.8 0 0 1-3.1 4.2" />
        <path d="M6.6 6.6C3.6 8.6 2 12 2 12s3.5 7 10 7a9.8 9.8 0 0 0 5.4-1.6" />
        <path d="M14.1 14.1A3 3 0 0 1 9.9 9.9" />
        <path d="m3 3 18 18" />
      </svg>
    </button>
  </div>

  <% if hint.present? %>
    <p class="mt-2 text-xs text-base-content/60"><%= hint %></p>
  <% end %>
</div>
