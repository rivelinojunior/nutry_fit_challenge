<% content_for :title, "Recuperar senha | Nutry.fit Challenge" %>

<section class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-md flex-col justify-center py-8">
  <%= render "devise/shared/brand" %>

  <div class="nutry-card p-6 sm:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold text-primary">Recuperação de acesso</p>
      <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content">Esqueceu sua senha?</h1>
      <p class="mt-2 text-sm leading-6 text-base-content/70">Informe seu e-mail e enviaremos as instruções para redefinir o acesso.</p>
    </div>

    <%= render "devise/shared/flash" %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "E-mail", class: "label pb-2 text-sm font-medium" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "voce@email.com", class: "input input-bordered w-full #{'input-error' if resource.errors[:email].any?}" %>
      </div>

      <%= f.submit "Enviar instruções", class: "btn btn-primary w-full rounded-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
