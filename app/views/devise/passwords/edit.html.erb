<% content_for :title, "Redefinir senha | Nutry.fit Challenge" %>

<section class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-md flex-col justify-center py-8">
  <%= render "devise/shared/brand" %>

  <div class="nutry-card p-6 sm:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold text-primary">Recuperação de acesso</p>
      <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content">Crie uma nova senha</h1>
      <p class="mt-2 text-sm leading-6 text-base-content/70">Escolha uma senha segura para voltar ao desafio.</p>
    </div>

    <%= render "devise/shared/flash" %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <%= render "devise/shared/password_field",
        form: f,
        resource: resource,
        attribute: :password,
        label_text: "Nova senha",
        autofocus: true,
        autocomplete: "new-password",
        hint: (@minimum_password_length ? "Use pelo menos #{@minimum_password_length} caracteres." : nil) %>

      <%= render "devise/shared/password_field",
        form: f,
        resource: resource,
        attribute: :password_confirmation,
        label_text: "Confirmar nova senha",
        autocomplete: "new-password" %>

      <%= f.submit "Salvar nova senha", class: "btn nutry-cta-gradient w-full rounded-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
