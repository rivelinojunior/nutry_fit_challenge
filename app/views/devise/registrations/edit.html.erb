<% content_for :title, "Minha conta | Nutry.fit Challenge" %>

<% content_for :authenticated_header do %>
  <header class="w-full bg-base-200">
    <div class="mx-auto flex h-14 w-full max-w-6xl items-center px-4 sm:px-6 mt-1">
      <%= link_to settings_path, class: "btn btn-ghost btn-square", aria: { label: "Voltar para configurações" }, data: { turbo: false } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m15 18-6-6 6-6" />
        </svg>
      <% end %>
    </div>
  </header>
<% end %>

<section class="mx-auto w-full max-w-xl px-4 pb-10 pt-8 sm:pt-12">
  <div class="mb-8">
    <p class="text-sm font-semibold text-primary">Configurações</p>
    <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content">Minha conta</h1>
    <p class="mt-2 text-sm leading-6 text-base-content/70">Atualize o nome exibido no desafio.</p>
  </div>

  <div class="nutry-card p-5 sm:p-6">
    <%= render "devise/shared/flash" %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :name, "Nome", class: "label pb-2 text-sm font-medium" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Seu nome", class: "input input-bordered w-full #{'input-error' if resource.errors[:name].any?}" %>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "label pb-2 text-sm font-medium" %>
        <%= f.email_field :email, autocomplete: "email", disabled: true, class: "input input-bordered w-full bg-base-200 text-base-content/60" %>
        <p class="mt-2 text-xs text-base-content/60">O e-mail de acesso não pode ser alterado por aqui.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <%= f.submit "Salvar alterações", class: "btn btn-primary rounded-full sm:min-w-48" %>
        <%= link_to "Voltar", settings_path, class: "btn btn-ghost rounded-full" %>
      </div>
    <% end %>
  </div>
</section>
