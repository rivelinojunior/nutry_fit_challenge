<% content_for :title, "Criar conta | Nutry.fit Challenge" %>

<section class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-md flex-col justify-center py-8">
  <%= render "devise/shared/brand" %>

  <div class="nutry-card p-6 sm:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold text-primary">Comece no desafio</p>
      <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content">Crie sua conta</h1>
      <p class="mt-2 text-sm leading-6 text-base-content/70">Entre com seus dados para acompanhar pontos, tarefas e ranking.</p>
    </div>

    <%= render "devise/shared/flash" %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :name, "Nome", class: "label pb-2 text-sm font-medium" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Seu nome", class: "input input-bordered w-full #{'input-error' if resource.errors[:name].any?}" %>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "label pb-2 text-sm font-medium" %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "voce@email.com", class: "input input-bordered w-full #{'input-error' if resource.errors[:email].any?}" %>
      </div>

      <%= render "devise/shared/password_field",
        form: f,
        resource: resource,
        attribute: :password,
        label_text: "Senha",
        autocomplete: "new-password",
        hint: (@minimum_password_length ? "Use pelo menos #{@minimum_password_length} caracteres." : nil) %>

      <%= render "devise/shared/password_field",
        form: f,
        resource: resource,
        attribute: :password_confirmation,
        label_text: "Confirmar senha",
        autocomplete: "new-password" %>

      <%= f.submit "Criar conta", class: "btn nutry-cta-gradient w-full rounded-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
