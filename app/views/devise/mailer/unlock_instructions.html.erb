<p style="margin:0 0 10px;font-size:12px;line-height:16px;font-weight:700;color:#1e970d;text-align:center;">
  <%= t("devise.mailer.unlock_instructions.eyebrow") %>
</p>

<h1 class="nutry-mail-headline" style="margin:0 0 20px;font-size:32px;line-height:38px;font-weight:800;letter-spacing:0;color:#111827;text-align:center;">
  <%= t("devise.mailer.unlock_instructions.title") %>
</h1>

<p style="margin:0 0 12px;font-size:15px;line-height:26px;color:#374151;text-align:center;">
  <%= t("devise.mailer.unlock_instructions.body") %>
</p>

<p style="margin:0 0 28px;font-size:14px;line-height:24px;color:#6b7280;text-align:center;">
  <%= t("devise.mailer.unlock_instructions.instructions") %>
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;margin:0 0 26px;">
  <tr>
    <td align="center" style="padding:0;">
      <%= link_to t("devise.mailer.unlock_instructions.cta"), unlock_url(@resource, unlock_token: @token), class: "nutry-mail-button", style: "display:inline-block;padding:14px 28px;border-radius:999px;background:#1EBA09;color:#ffffff;font-size:15px;font-weight:700;line-height:20px;text-decoration:none;box-shadow:0 10px 24px -16px rgba(30,186,9,0.8);" %>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px;font-size:12px;line-height:20px;color:#6b7280;text-align:center;">
  <%= t("devise.mailer.unlock_instructions.footer") %>
</p>

<p style="margin:0;font-size:11px;line-height:18px;color:#9ca3af;text-align:center;word-break:break-all;">
  <%= unlock_url(@resource, unlock_token: @token) %>
</p>
