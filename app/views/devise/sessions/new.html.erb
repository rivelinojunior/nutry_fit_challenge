<% content_for :title, "Entrar | Nutry.fit Challenge" %>

<section class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-md flex-col justify-center py-8">
  <%= render "devise/shared/brand" %>

  <div class="nutry-card p-6 sm:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold text-primary">Acesso ao desafio</p>
      <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content">Entrar na sua conta</h1>
      <p class="mt-2 text-sm leading-6 text-base-content/70">Acompanhe suas tarefas, pontos e ranking da comunidade.</p>
    </div>

    <%= render "devise/shared/flash" %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "E-mail", class: "label pb-2 text-sm font-medium" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "voce@email.com", class: "input input-bordered w-full" %>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, "Senha", class: "label pb-2 text-sm font-medium" %>
          <%= link_to "Esqueci", new_password_path(resource_name), class: "link link-hover pb-2 text-xs font-medium text-base-content/60" if devise_mapping.recoverable? %>
        </div>
        <%= render "devise/shared/password_field", form: f, resource: resource, attribute: :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-base-300 bg-base-100 p-3 text-sm">
          <%= f.check_box :remember_me, class: "checkbox checkbox-primary checkbox-sm" %>
          <span>Manter conectado neste dispositivo</span>
        </label>
      <% end %>

      <%= f.submit "Entrar", class: "btn nutry-cta-gradient w-full rounded-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
