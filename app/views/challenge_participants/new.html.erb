<% content_for :title, "Entrar no desafio" %>

<section class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-3xl flex-col justify-center px-4 py-8">
  <div class="mb-6">
    <p class="text-sm font-semibold text-primary">Participante</p>
    <h1 class="mt-2 text-2xl font-bold tracking-normal text-base-content sm:text-3xl">Entrar no desafio</h1>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-base-content/70">
      Use o código compartilhado pela administração para participar antes do início.
    </p>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success mb-5"><%= notice %></div>
  <% end %>

  <% if alert.present? %>
    <div class="alert alert-error mb-5"><%= alert %></div>
  <% end %>

  <div class="nutry-card p-5 sm:p-6">
    <%= form_with scope: :challenge_participant, url: challenge_participant_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :challenge_code, "Código do desafio", class: "label pb-2 text-sm font-medium" %>
        <%= form.text_field :challenge_code,
          autofocus: true,
          autocomplete: "off",
          placeholder: "ABC123",
          class: "input input-bordered w-full uppercase tracking-normal" %>
      </div>

      <%= form.submit "Entrar no desafio", class: "btn nutry-cta-gradient w-full rounded-full" %>
    <% end %>
  </div>
</section>
