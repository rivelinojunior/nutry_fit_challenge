<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f8fafc;
        color: #1f2937;
        font-family: Poppins, "Segoe UI", Arial, sans-serif;
      }

      a {
        color: #1e970d;
      }

      @media screen and (max-width: 640px) {
        .nutry-mail-shell {
          width: 100% !important;
        }

        .nutry-mail-gutter {
          padding-left: 20px !important;
          padding-right: 20px !important;
        }

        .nutry-mail-card {
          padding: 28px 22px !important;
        }

        .nutry-mail-headline {
          font-size: 28px !important;
          line-height: 34px !important;
        }

        .nutry-mail-button {
          display: block !important;
          width: 100% !important;
          box-sizing: border-box !important;
          text-align: center !important;
        }
      }
    </style>
  </head>

  <body style="margin:0;padding:0;background:#f8fafc;color:#1f2937;font-family:Poppins,'Segoe UI',Arial,sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;background:#f8fafc;">
      <tr>
        <td class="nutry-mail-gutter" style="padding:44px 24px 36px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="nutry-mail-shell" style="width:100%;max-width:560px;margin:0 auto;border-collapse:collapse;">
            <tr>
              <td align="center" style="padding:0 0 28px;">
                <table role="presentation" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:0 auto;">
                  <tr>
                    <td style="font-size:18px;line-height:22px;font-weight:800;color:#111827;letter-spacing:0;">
                      Nutry<span style="color:#1EBA09;">.fit</span>
                    </td>
                    <td style="padding:2px 0 0 8px;font-size:12px;line-height:16px;font-weight:700;color:#374151;vertical-align:middle;">
                      Challenge
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="nutry-mail-card" style="padding:36px 34px;border:1px solid #e5e7eb;border-radius:14px;background:#ffffff;box-shadow:0 1px 2px rgba(24,24,27,0.06),0 1px 3px rgba(24,24,27,0.08);">
                <%= yield %>
              </td>
            </tr>

            <tr>
              <td style="padding:24px 4px 0;font-size:12px;line-height:20px;color:#6b7280;text-align:center;">
                <%= t("mailer_layout.security_notice") %><br>
                <%= t("mailer_layout.link_fallback") %>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
