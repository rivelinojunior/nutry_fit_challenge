<% content_for :title, "Configurações" %>

<% user_name = current_user.name.presence || current_user.email %>
<% user_initial = user_name.first.upcase %>

<section class="mx-auto flex w-full max-w-xl flex-col px-4 pb-10 pt-10 sm:min-h-[calc(100vh-4rem)] sm:justify-start sm:pt-16">
  <%= render "devise/shared/flash" %>

  <div class="flex flex-col items-center text-center">
    <div class="flex size-28 items-center justify-center rounded-full bg-primary text-5xl font-semibold text-primary-content shadow-nutry-card" aria-hidden="true">
      <%= user_initial %>
    </div>

    <h1 class="mt-5 max-w-full truncate text-2xl font-bold tracking-normal text-base-content sm:text-3xl">
      <%= user_name %>
    </h1>
  </div>

  <div class="mt-16 space-y-3 sm:mt-20">
    <%= link_to edit_settings_password_path, class: "nutry-card flex min-h-20 items-center gap-4 p-4 transition hover:border-primary/30 focus-visible:border-primary" do %>
      <span class="flex size-12 shrink-0 items-center justify-center rounded-full bg-base-200 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          <path d="M12 16h.01" />
        </svg>
      </span>

      <span class="min-w-0 flex-1 text-left">
        <span class="block truncate text-base font-semibold text-base-content">Senha</span>
        <span class="mt-1 block truncate text-sm font-medium text-base-content/60">Altere sua senha de acesso.</span>
      </span>

      <span class="shrink-0 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    <% end %>

    <%= link_to edit_user_registration_path, class: "nutry-card flex min-h-20 items-center gap-4 p-4 transition hover:border-primary/30 focus-visible:border-primary" do %>
      <span class="flex size-12 shrink-0 items-center justify-center rounded-full bg-base-200 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="m16 11 2 2 4-4" />
        </svg>
      </span>

      <span class="min-w-0 flex-1 text-left">
        <span class="block truncate text-base font-semibold text-base-content">Editar conta</span>
        <span class="mt-1 block truncate text-sm font-medium text-base-content/60">Atualize suas informações pessoais.</span>
      </span>

      <span class="shrink-0 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    <% end %>

    <%= link_to settings_account_cancellation_path, class: "nutry-card flex min-h-20 items-center gap-4 p-4 transition hover:border-primary/30 focus-visible:border-primary" do %>
      <span class="flex size-12 shrink-0 items-center justify-center rounded-full bg-base-200 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 11v6" />
          <path d="M14 11v6" />
          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
          <path d="M3 6h18" />
          <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
        </svg>
      </span>

      <span class="min-w-0 flex-1 text-left">
        <span class="block truncate text-base font-semibold text-base-content">Cancelar conta</span>
        <span class="mt-1 block truncate text-sm font-medium text-base-content/60">Encerre seu acesso ao app.</span>
      </span>

      <span class="shrink-0 text-base-content/60" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    <% end %>
  </div>
</section>
