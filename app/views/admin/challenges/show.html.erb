<% content_for :title, @challenge&.name || "Tarefas do desafio" %>

<section class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <header class="flex flex-col gap-4 rounded-xl border border-base-300 bg-base-100 p-5 shadow-sm sm:flex-row sm:items-stretch sm:justify-between">
    <div>
      <p class="text-sm font-medium text-primary">Admin</p>
      <h1 class="text-2xl font-semibold text-base-content"><%= @challenge&.name || "Tarefas do desafio" %></h1>
      <% if @challenge.present? %>
        <p class="mt-1 text-sm text-base-content/70">
          <%= @challenge.start_date.strftime("%d/%m/%Y") %> até <%= @challenge.end_date.strftime("%d/%m/%Y") %>
        </p>
        <p class="mt-2 text-sm font-semibold text-base-content">
          Código: <span class="font-mono"><%= @challenge.challenge_code %></span>
        </p>
      <% else %>
        <p class="mt-1 text-sm text-base-content/70">Nenhum desafio encontrado para este usuário.</p>
      <% end %>
    </div>

    <div class="flex items-center justify-between gap-3 sm:flex-col sm:items-end sm:justify-between">
      <div class="flex flex-wrap items-center gap-2 sm:justify-end">
        <% if @challenge.present? %>
          <span class="badge <%= @challenge.status == "published" ? "badge-success" : "badge-outline" %>">
            <%= @challenge.status == "published" ? "Publicado" : "Rascunho" %>
          </span>
          <% if @challenge_started %>
            <span class="badge badge-warning">Iniciado</span>
          <% end %>
        <% end %>
      </div>

      <%= render "admin/challenge_tasks/publish_action", challenge: @challenge, tasks_by_date: @tasks_by_date %>
    </div>
  </header>

  <%= render "admin/challenge_tasks/flash", message: notice, kind: :notice %>
  <%= render "admin/challenge_tasks/flash", message: alert, kind: :alert %>
  <%= render "admin/challenge_tasks/errors", errors: [] %>

  <% if @challenge.present? && !@challenge_started %>
    <%= render "admin/challenge_tasks/form", challenge: @challenge, task_form: @task_form, challenge_started: @challenge_started %>
  <% end %>

  <%= render "admin/challenge_tasks/task_list", challenge: @challenge, tasks_by_date: @tasks_by_date, challenge_started: @challenge_started %>
</section>
