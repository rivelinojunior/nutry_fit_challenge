<section id="challenge_task_form" class="rounded-xl border border-base-300 bg-base-100 p-5 shadow-sm">
  <% recurrence_type = task_form["recurrence_type"] %>
  <% task_links = task_form.fetch("links", []) %>
  <% task_links = [ { "label" => "", "url" => "" } ] if task_links.blank? %>
  <h2 class="text-lg font-semibold">Nova tarefa</h2>

  <%= form_with scope: :challenge_task,
                url: challenge.present? ? admin_challenge_tasks_path(challenge) : "#",
                method: :post,
                class: "mt-5 grid gap-4",
                data: { controller: "challenge-task-recurrence challenge-task-links" } do |form| %>
    <fieldset class="grid gap-4" <%= "disabled" if challenge.blank? || challenge_started %>>
      <div>
        <%= form.label :name, "Nome", class: "label" %>
        <%= form.text_field :name, value: task_form["name"], class: "input input-bordered w-full", required: true %>
      </div>

      <div>
        <%= form.label :description, "Descrição", class: "label" %>
        <%= form.text_area :description, value: task_form["description"], rows: 3, class: "textarea textarea-bordered w-full" %>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <%= form.label :points, "Pontos", class: "label" %>
          <%= form.number_field :points, value: task_form["points"], min: 1, class: "input input-bordered w-full", required: true %>
        </div>

        <div>
          <%= form.label :start_time, "Início", class: "label" %>
          <%= form.text_field :start_time,
                              value: task_form["start_time"],
                              placeholder: "00:00",
                              inputmode: "numeric",
                              maxlength: 5,
                              pattern: "([01][0-9]|2[0-3]):[0-5][0-9]",
                              title: "Use o formato 24h, como 08:30 ou 17:45",
                              class: "input input-bordered w-full",
                              data: {
                                controller: "time-input",
                                action: "input->time-input#sanitize blur->time-input#complete"
                              } %>
        </div>

        <div>
          <%= form.label :end_time, "Fim", class: "label" %>
          <%= form.text_field :end_time,
                              value: task_form["end_time"],
                              placeholder: "00:00",
                              inputmode: "numeric",
                              maxlength: 5,
                              pattern: "([01][0-9]|2[0-3]):[0-5][0-9]",
                              title: "Use o formato 24h, como 08:30 ou 17:45",
                              class: "input input-bordered w-full",
                              data: {
                                controller: "time-input",
                                action: "input->time-input#sanitize blur->time-input#complete"
                              } %>
        </div>
      </div>

      <div>
        <%= form.label :recurrence_type, "Recorrência", class: "label" %>
        <%= form.select :recurrence_type,
                        options_for_select([ [ "Todos os dias", "daily" ], [ "Dias da semana", "weekdays" ], [ "Data específica", "specific_date" ] ], task_form["recurrence_type"]),
                        {},
                        class: "select select-bordered w-full",
                        data: {
                          action: "challenge-task-recurrence#update",
                          challenge_task_recurrence_target: "recurrenceType"
                        } %>
      </div>

      <div class="<%= "hidden" unless recurrence_type == "weekdays" %>" data-challenge-task-recurrence-target="weekdays">
        <span class="label">Dias da semana</span>
        <div class="grid gap-2 sm:grid-cols-4">
          <% [ [ "Dom", 0 ], [ "Seg", 1 ], [ "Ter", 2 ], [ "Qua", 3 ], [ "Qui", 4 ], [ "Sex", 5 ], [ "Sáb", 6 ] ].each do |label, value| %>
            <label class="flex items-center gap-2 rounded-md border border-base-300 px-3 py-2 text-sm">
              <%= check_box_tag "challenge_task[weekdays][]", value, task_form.fetch("weekdays", []).map(&:to_s).include?(value.to_s), class: "checkbox checkbox-primary checkbox-sm", disabled: recurrence_type != "weekdays" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="<%= "hidden" unless recurrence_type == "specific_date" %>" data-challenge-task-recurrence-target="specificDate">
        <%= form.label :specific_date, "Data específica", class: "label" %>
        <%= form.date_field :specific_date, value: task_form["specific_date"], min: challenge&.start_date, max: challenge&.end_date, class: "input input-bordered w-full", disabled: recurrence_type != "specific_date" %>
      </div>

      <div class="grid gap-3">
        <div>
          <span class="label">Links da tarefa</span>
          <p class="text-xs text-base-content/60">Opcional. Use links completos começando com http ou https.</p>
        </div>

        <div class="grid gap-3" data-challenge-task-links-target="list">
          <% task_links.each do |link| %>
            <% link_label = link[:label].presence || link["label"] %>
            <% link_url = link[:url].presence || link["url"] %>
            <div class="grid gap-3 rounded-lg border border-base-300 p-3 sm:grid-cols-[1fr_1fr_auto]" data-challenge-task-links-target="row">
              <label class="grid gap-1">
                <span class="label">Nome do link</span>
                <%= text_field_tag "challenge_task[links][][label]", link_label, class: "input input-bordered w-full", placeholder: "Grupo do WhatsApp" %>
              </label>

              <label class="grid gap-1">
                <span class="label">URL</span>
                <%= url_field_tag "challenge_task[links][][url]", link_url, class: "input input-bordered w-full", placeholder: "https://..." %>
              </label>

              <button type="button" class="btn btn-ghost btn-sm rounded-full self-end" data-action="challenge-task-links#remove">Remover</button>
            </div>
          <% end %>
        </div>

        <button type="button" class="btn btn-outline btn-sm rounded-full sm:w-fit" data-action="challenge-task-links#add">Adicionar link</button>

        <template data-challenge-task-links-target="template">
          <div class="grid gap-3 rounded-lg border border-base-300 p-3 sm:grid-cols-[1fr_1fr_auto]" data-challenge-task-links-target="row">
            <label class="grid gap-1">
              <span class="label">Nome do link</span>
              <input type="text" name="challenge_task[links][][label]" class="input input-bordered w-full" placeholder="Grupo do WhatsApp">
            </label>

            <label class="grid gap-1">
              <span class="label">URL</span>
              <input type="url" name="challenge_task[links][][url]" class="input input-bordered w-full" placeholder="https://...">
            </label>

            <button type="button" class="btn btn-ghost btn-sm rounded-full self-end" data-action="challenge-task-links#remove">Remover</button>
          </div>
        </template>
      </div>
    </fieldset>

    <% if challenge_started %>
      <p class="text-sm text-warning">O desafio já começou. Não é possível gerar novas tarefas.</p>
    <% elsif challenge.blank? %>
      <p class="text-sm text-warning">Nenhum desafio encontrado para este usuário.</p>
    <% end %>

    <%= form.submit "Adicionar Tarefa", disabled: challenge.blank? || challenge_started, class: "btn btn-primary rounded-full sm:w-fit" %>
  <% end %>
</section>
