<% content_for :title, "Tarefas do desafio" %>

<section class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <header class="flex flex-col gap-4 rounded-xl border border-base-300 bg-base-100 p-5 shadow-sm sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-medium text-primary">Admin</p>
      <h1 class="text-2xl font-semibold text-base-content">Tarefas do desafio</h1>
      <% if @challenge.present? %>
        <p class="mt-1 text-sm text-base-content/70">
          <%= @challenge.name %> · <%= @challenge.start_date.strftime("%d/%m/%Y") %> até <%= @challenge.end_date.strftime("%d/%m/%Y") %>
        </p>
        <p class="mt-2 text-sm font-semibold text-base-content">
          Código: <span class="font-mono"><%= @challenge.challenge_code %></span>
        </p>
      <% else %>
        <p class="mt-1 text-sm text-base-content/70">Crie um desafio antes de gerar tarefas.</p>
      <% end %>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% if @challenge.present? %>
        <span class="badge <%= @challenge.status == "published" ? "badge-success" : "badge-outline" %>">
          <%= @challenge.status == "published" ? "Publicado" : "Rascunho" %>
        </span>
        <% if @challenge_started %>
          <span class="badge badge-warning">Iniciado</span>
        <% end %>
      <% end %>
    </div>
  </header>

  <% if notice.present? %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <% if alert.present? %>
    <div class="alert alert-error"><%= alert %></div>
  <% end %>

  <% if @errors.present? %>
    <div class="alert alert-error">
      <ul class="list-disc pl-5">
        <% @errors.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,24rem)]">
    <%= render "form", challenge: @challenge, task_form: @task_form, challenge_started: @challenge_started %>

    <aside class="rounded-xl border border-base-300 bg-base-100 p-5 shadow-sm">
      <h2 class="text-lg font-semibold">Publicação</h2>
      <p class="mt-1 text-sm text-base-content/70">
        Revise as tarefas materializadas antes de publicar o desafio.
      </p>

      <%= button_to "Publicar desafio",
                    @challenge.present? ? admin_publish_challenge_path(@challenge) : "#",
                    method: :patch,
                    disabled: @challenge.blank? || @tasks_by_date.blank? || @challenge.status == "published",
                    data: { turbo_confirm: "Publicar este desafio com as tarefas atuais?" },
                    class: "btn btn-primary mt-4 w-full rounded-full" %>
    </aside>
  </div>

  <%= render "task_list", challenge: @challenge, tasks_by_date: @tasks_by_date, challenge_started: @challenge_started %>
</section>
