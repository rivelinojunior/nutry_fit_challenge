<% user_name = current_user.name.presence || current_user.email %>
<% user_initial = user_name.first.upcase %>
<% current_participant = local_assigns.fetch(:current_participant, nil) ||
  current_user.participants
    .joins(:challenge)
    .includes(:challenge)
    .where(challenges: { end_date: Date.current.. })
    .order(joined_at: :desc)
    .first %>
<% current_challenge = current_participant&.challenge %>

<nav class="min-h-full w-[min(22rem,calc(100vw-2rem))] rounded-r-3xl bg-base-100 px-6 py-8 shadow-xl sm:w-96" aria-label="Menu principal">
  <ul class="flex w-full flex-col gap-4 text-base-content">
    <li>
      <%= link_to edit_user_registration_path, class: "grid min-h-14 grid-cols-[3rem_1fr] items-center gap-4 rounded-full py-2 pr-4 transition hover:bg-base-200 focus:bg-base-200" do %>
        <span class="flex size-12 shrink-0 items-center justify-center rounded-full bg-primary text-lg font-bold text-primary-content" aria-hidden="true">
          <%= user_initial %>
        </span>
        <span class="min-w-0 truncate text-base font-normal"><%= user_name %></span>
      <% end %>
    </li>

    <% if current_challenge.present? %>
      <li>
        <%= link_to root_path, class: "grid min-h-14 grid-cols-[3rem_1fr] items-center gap-4 rounded-full bg-[#f2f2f2] py-2 pl-[10px] pr-4 transition hover:bg-[#ededed] focus:bg-[#ededed]" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="size-8 shrink-0 justify-self-center" viewBox="0 0 512 512" fill="none" aria-hidden="true">
            <path d="M352 274C354 271 358 271 360 274L511 502C514 506 511 512 506 512H198C193 512 190 506 193 502L352 274Z" fill="#546F78" />
            <path d="M360 274L511 502C514 506 511 512 506 512H424L302 317L352 274C354 271 358 271 360 274Z" fill="#4d4d4d" />
            <path d="M207 195C210 191 216 191 219 195L426 501C429 506 426 512 420 512H7C1 512 -2 506 1 501L207 195Z" fill="#6f6d6d" />
            <path d="M213 192C215 192 217 193 219 195L426 501C429 506 426 512 420 512H400L205 208L213 192Z" fill="#4d4d4d" />
            <path d="M207 195C210 191 216 191 219 195L289 298L254 335C251 338 246 338 243 335L214 312L184 337C181 340 176 340 173 337L137 305L207 195Z" fill="#D9D9D9" />
            <path d="M213 192C215 192 217 193 219 195L289 298L254 335C251 338 246 338 243 335L205 208L213 192Z" fill="#CFCFCF" />
            <rect x="205" y="1" width="17" height="210" rx="8.5" fill="#4d4d4d" />
            <path d="M299 61H421C429 61 433 70 428 76L396 119L428 162C433 168 429 177 421 177H306C302 177 299 174 299 170V61Z" fill="#178F07" />
            <path d="M299 130H356L299 177V130Z" fill="#116B05" />
            <rect x="214" y="15" width="143" height="116" rx="8" fill="#1DB309" />
          </svg>
          <span class="min-w-0 truncate text-base font-normal"><%= current_challenge.name %></span>
        <% end %>
      </li>
    <% end %>

    <li>
      <span class="grid min-h-14 cursor-not-allowed grid-cols-[3rem_1fr] items-center gap-4 rounded-full py-2 pr-4 text-base-content" aria-disabled="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-7 shrink-0 justify-self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V4s-1 1-4 1-5-2-8-2-4 1-4 1z" />
          <path d="M4 22V15" />
        </svg>
        <span class="text-base font-normal">Desafios concluídos</span>
      </span>
    </li>

    <li>
      <%= link_to edit_user_registration_path, class: "grid min-h-14 grid-cols-[3rem_1fr] items-center gap-4 rounded-full py-2 pr-4 transition hover:bg-base-200 focus:bg-base-200" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-7 shrink-0 justify-self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.38a2 2 0 0 0-.73-2.73l-.15-.09a2 2 0 0 1-1-1.74v-.51a2 2 0 0 1 1-1.72l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <span class="text-base font-normal">Configurações</span>
      <% end %>
    </li>

    <li>
      <%= button_to destroy_user_session_path,
        method: :delete,
        form: { class: "w-full" },
        class: "grid min-h-14 w-full grid-cols-[3rem_1fr] items-center gap-4 rounded-full py-2 pr-4 text-left text-base-content transition hover:bg-base-200 focus:bg-base-200" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-7 shrink-0 justify-self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
          <path d="M16 17l5-5-5-5" />
          <path d="M21 12H9" />
        </svg>
        <span class="text-base font-normal">Sair</span>
      <% end %>
    </li>
  </ul>
</nav>
