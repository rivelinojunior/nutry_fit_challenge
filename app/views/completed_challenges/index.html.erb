<% content_for :title, "Desafios concluídos | Nutry.fit Challenge" %>

<section class="mx-auto flex w-full max-w-3xl flex-col gap-5 px-4 py-4 sm:py-8">
  <div>
    <h1 class="mt-1 text-2xl font-bold tracking-normal text-base-content sm:text-3xl">Desafios concluídos</h1>
    <p class="mt-2 text-sm leading-6 text-base-content/65">Veja seu resultado final nos desafios que já terminaram.</p>
  </div>

  <% if @completed_challenge_items.any? %>
    <div class="space-y-3">
      <% @completed_challenge_items.each do |completed_challenge_item| %>
        <% challenge = completed_challenge_item.challenge %>
        <% challenge_name = challenge.name.presence || "Desafio" %>
        <% challenge_initial = challenge_name.first.upcase %>

        <%= link_to completed_challenge_path(challenge), class: "nutry-card flex items-center justify-between gap-3 border border-base-300 bg-base-100 p-4 transition hover:border-primary/30 focus-visible:border-primary" do %>
          <div class="flex min-w-0 items-center gap-3">
            <span class="w-8 shrink-0 text-center text-sm font-medium text-base-content">
              <%= completed_challenge_item.rank ? "##{completed_challenge_item.rank}" : "-" %>
            </span>
            <span class="flex size-12 shrink-0 items-center justify-center rounded-full border border-base-300 bg-base-200 text-lg font-bold text-base-content">
              <%= challenge_initial %>
            </span>
            <div class="min-w-0">
              <p class="truncate text-sm font-bold text-base-content"><%= challenge_name %></p>
              <span class="mt-1 inline-flex items-center rounded-full border border-base-300 bg-base-100 px-2 py-0.5 text-[0.68rem] font-medium text-base-content">
                <%= completed_challenge_item.total_points %> pts
              </span>
            </div>
          </div>

          <p class="shrink-0 text-xs font-semibold text-base-content/55"><%= completed_challenge_item.active_days %> dias</p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="nutry-card p-5">
      <p class="text-sm leading-6 text-base-content/70">Seus desafios concluídos aparecerão aqui quando terminarem.</p>
    </div>
  <% end %>
</section>
