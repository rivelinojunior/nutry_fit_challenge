<% content_for :title, "Entrar em um desafio" %>

<section class="relative mx-auto flex min-h-[calc(100vh-1.5rem)] w-full max-w-md flex-col justify-start px-4 py-3 sm:min-h-[calc(100vh-4rem)] sm:py-8">
  <%= render "devise/shared/brand" %>

  <div class="mb-6 text-center">
    <h1 class="mt-2 text-xl font-bold tracking-normal text-base-content sm:text-2xl">Entrar em um desafio</h1>
    <p class="mt-2 text-sm leading-6 text-base-content/70">Peça o código do desafio para o organizador</p>
  </div>

  <div class="nutry-card p-5 sm:p-6">
    <%= form_with url: join_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :challenge_code, "Código do desafio", class: "label pb-2 text-sm font-medium" %>
        <%= form.text_field :challenge_code,
          value: @challenge_code,
          autofocus: true,
          autocomplete: "off",
          required: true,
          placeholder: "ABC123",
          class: "input input-bordered w-full uppercase tracking-normal #{'input-error' if @error_message.present?}",
          oninput: "this.value = this.value.trim().toUpperCase()" %>

        <% if @error_message.present? %>
          <p class="mt-2 text-sm text-error"><%= @error_message %></p>
        <% end %>
      </div>

      <%= form.submit "Entrar no desafio", class: "btn nutry-cta-gradient w-full rounded-full" %>
    <% end %>
  </div>
</section>
