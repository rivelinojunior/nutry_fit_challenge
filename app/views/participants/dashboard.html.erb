<% content_for :title, "#{@challenge.name} | Hoje" %>

<% state_styles = {
  "available" => { label: "Disponível", badge: "badge-outline border-primary/30 bg-base-100 text-primary", text: "text-primary", panel: "border-base-300 bg-base-100" },
  "checked" => { label: "Feita", badge: "badge-outline border-primary/30 bg-base-100 text-primary", text: "text-primary", panel: "border-base-300 bg-base-100" },
  "future" => { label: "Em breve", badge: "badge-outline border-warning/30 bg-base-100 text-warning", text: "text-warning", panel: "border-base-300 bg-base-100" },
  "expired" => { label: "Expirada", badge: "badge-outline bg-base-100 text-base-content/70", text: "text-base-content/50", panel: "border-base-300 bg-[#ededed]" }
} %>
<% task_sections = %w[available future checked expired] %>

<section class="mx-auto flex w-full max-w-3xl flex-col gap-5 px-4 py-4 sm:py-8">
  <% if notice.present? || alert.present? %>
    <div class="alert <%= notice.present? ? "alert-success" : "alert-error" %>">
      <span><%= notice.presence || alert %></span>
    </div>
  <% end %>

  <div>
    <h1 class="mt-1 text-2xl font-bold tracking-normal text-base-content sm:text-3xl"><%= @challenge.name %></h1>
    <p class="mt-2 text-sm text-base-content/65"><%= Time.current.in_time_zone(@challenge.timezone).strftime("%d/%m/%Y") %></p>
  </div>

  <div class="grid grid-cols-3 gap-2 sm:gap-3">
    <div class="nutry-card relative p-3 pr-10 sm:p-4 sm:pr-12">
      <span class="absolute right-3 top-3 flex size-7 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 14.66v1.626a2 2 0 0 1-.976 1.696A5 5 0 0 0 7 21.978" />
          <path d="M14 14.66v1.626a2 2 0 0 0 .976 1.696A5 5 0 0 1 17 21.978" />
          <path d="M18 9h1.5a1 1 0 0 0 0-2H18" />
          <path d="M4 22h16" />
          <path d="M6 9a6 6 0 0 0 12 0V3a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1z" />
          <path d="M6 9H4.5a1 1 0 0 1 0-2H6" />
        </svg>
      </span>
      <p class="text-xs font-medium text-base-content/60 sm:text-sm">Posição</p>
      <p class="mt-2 text-xl font-bold text-base-content sm:text-2xl"><%= @participant_rank ? "#{@participant_rank}º" : "-" %></p>
    </div>

    <div class="nutry-card relative p-3 pr-10 sm:p-4 sm:pr-12">
      <span class="absolute right-3 top-3 flex size-7 items-center justify-center rounded-full bg-yellow-100 text-yellow-500" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.12 2.12 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.12 2.12 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.14a2.12 2.12 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.12 2.12 0 0 0 1.597-1.16z" />
        </svg>
      </span>
      <p class="text-xs font-medium text-base-content/60 sm:text-sm">Pontos</p>
      <p class="mt-2 text-xl font-bold text-base-content sm:text-2xl"><%= @participant_ranking_item&.total_points || 0 %></p>
    </div>

    <div class="nutry-card relative p-3 pr-10 sm:p-4 sm:pr-12">
      <span class="absolute right-3 top-3 flex size-7 items-center justify-center rounded-full bg-orange-100 text-orange-500" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8.5 14.5A2.5 2.5 0 0 0 11 17c0-1.38.5-2 1-3 1.072-2.143.224-4.054-2-6 .5 2-2.5 4-2.5 6.5" />
          <path d="M12 22c4.5-2 7-5.5 7-10a8 8 0 0 0-4-7c.5 2-1 3-2 4-1.5-3-4-4-4-7C5.5 4.5 4 8 4 12c0 4.5 3.5 8 8 10Z" />
        </svg>
      </span>
      <p class="text-xs font-medium text-base-content/60 sm:text-sm">Dias ativos</p>
      <p class="mt-2 text-xl font-bold text-base-content sm:text-2xl"><%= @participant_ranking_item&.active_days || 0 %></p>
    </div>
  </div>

  <div class="tabs tabs-border tabs-lg">
    <label class="tab gap-2 px-1 text-sm font-semibold sm:px-4 sm:text-base">
      <input type="radio" name="participant_dashboard_tabs" checked="checked" />
      Hoje
      <span class="badge badge-outline badge-sm"><%= @today_tasks.size %></span>
    </label>
    <div class="tab-content pt-4">
      <% if @today_tasks.any? %>
        <div class="space-y-5">
          <% task_sections.each do |state| %>
            <% section_tasks = @today_tasks.select { |task_item| task_item.state == state } %>
            <% next if section_tasks.empty? %>

            <div>
              <div class="space-y-3">
                <% section_tasks.each do |task_item| %>
                  <% task = task_item.challenge_task %>
                  <% style = state_styles.fetch(task_item.state) %>

                  <article class="nutry-card border <%= style[:panel] %> p-4">
                    <div class="flex items-center justify-between gap-4">
                      <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                          <h3 class="text-base font-semibold tracking-normal text-base-content"><%= task.name %></h3>
                          <% if task.description.present? %>
                            <details class="nutry-description-disclosure group relative inline-flex">
                              <summary class="flex size-5 cursor-pointer select-none items-center justify-center rounded-full border border-base-300 bg-base-100 text-xs font-bold leading-none text-base-content/60 outline-none transition hover:border-primary/30 hover:text-primary focus-visible:border-primary focus-visible:text-primary">
                                <span aria-hidden="true">i</span>
                                <span class="sr-only">Ver descrição da tarefa</span>
                              </summary>
                              <div class="nutry-description-popover absolute left-0 top-full z-20 mt-2 w-64 max-w-[calc(100vw-3rem)] rounded-lg border border-base-300 bg-base-100 p-3 text-xs font-medium leading-5 text-base-content/70 shadow-sm">
                                <%= task.description %>
                              </div>
                            </details>
                          <% end %>
                          <% unless task_item.state == "available" %>
                            <span class="badge <%= style[:badge] %>"><%= style[:label] %></span>
                          <% end %>
                        </div>

                        <div class="mt-3 flex flex-wrap gap-2 text-xs font-medium text-base-content/60">
                          <span><%= task.points %> pts</span>
                          <% if task.allowed_start_time.present? %>
                            <span>Das <%= task.allowed_start_time.strftime("%H:%M") %> às <%= task.allowed_end_time.strftime("%H:%M") %></span>
                          <% else %>
                            <span>Disponível o dia todo</span>
                          <% end %>
                        </div>
                      </div>

                      <% if task_item.state == "available" %>
                        <div class="shrink-0">
                          <%= button_to "Concluir",
                            participant_checkins_path(@participant),
                            params: { challenge_task_id: task.id },
                            class: "btn btn-primary rounded-full" %>
                        </div>
                      <% end %>
                    </div>
                  </article>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="nutry-card p-5">
          <p class="text-sm leading-6 text-base-content/70">Nenhuma tarefa liberada para hoje.</p>
        </div>
      <% end %>
    </div>

    <label class="tab gap-2 px-1 text-sm font-semibold sm:px-4 sm:text-base">
      <input type="radio" name="participant_dashboard_tabs" />
      Ranking
      <span class="badge badge-outline badge-sm"><%= @ranking_items.size %></span>
    </label>
    <div class="tab-content pt-4">
      <h2 class="mb-3 text-lg font-bold tracking-normal text-base-content">Ranking</h2>

      <% if @ranking_items.any? %>
        <div class="nutry-card divide-y divide-base-300 overflow-hidden">
          <% @ranking_items.each_with_index do |ranking_item, index| %>
            <div class="flex items-center justify-between gap-3 px-4 py-3 <%= "bg-primary/5" if ranking_item.participant.id == @participant.id %>">
              <div class="flex min-w-0 items-center gap-3">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-base-200 text-sm font-bold text-base-content">
                  <%= index + 1 %>
                </span>
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold text-base-content"><%= ranking_item.participant.user.name %></p>
                  <p class="text-xs text-base-content/55"><%= ranking_item.active_days %> dias ativos</p>
                </div>
              </div>

              <p class="shrink-0 text-sm font-bold text-primary"><%= ranking_item.total_points %> pts</p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="nutry-card p-5">
          <p class="text-sm leading-6 text-base-content/70">O ranking aparece quando participantes entram no desafio.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
